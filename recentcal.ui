    <property name="styleSheet">
     <string notr="true">QListView, QListWidget {
    background-color: #FAFAFA;
    border: 1px solid #EAEAEA;
    border-radius: 6px;
    padding: 5px;
    outline: 0; /* Removes the ugly dotted focus box around items */
}

/* Style each individual history row item */
QListView::item, QListWidget::item {
    background-color: #FFFFFF;
    border-bottom: 1px solid #F0F0F0;
    padding: 12px;
    margin-bottom: 4px;
    border-radius: 4px;
    color: #111111;
    font-size: 14px;
}

/* Highlight color when hovering mouse over a calculation row */
QListView::item:hover, QListWidget::item:hover {
    background-color: #F4F4F4;
    color: #000000;
}

/* Highlight color when a calculation row is selected/clicked */
QListView::item:selected, QListWidget::item:selected {
    background-color: #E5E5E5;
    color: #000000;
}</string>
